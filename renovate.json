{
  "extends": [
    ":automergeMinor",
    ":rebaseStalePrs",
    ":separateMajorReleases",
    "config:recommended"
  ],
  "schedule": [
    "every weekend"
  ],
  "timezone": "US/Eastern",
  "lockFileMaintenance": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["(^|/)Dockerfile\\.dagster-k8s$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>[^\\s]+)\\nARG [A-Z_]+=(?<currentValue>[^\\s]+)"
      ]
    }
  ],
  "packageRules": [
    {
      "groupName": "dagster-plugins",
      "matchPackageNames": [
        "dagster{/,}**",
        "dagster-io/dagster"
      ]
    },
    {
      "matchDatasources": ["python-version"],
      "automerge": false
    }
  ]
}
