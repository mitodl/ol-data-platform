{
  "extends": [
    ":automergeMinor",
    ":rebaseStalePrs",
    ":separateMajorReleases",
    "config:recommended"
  ],
  "schedule": [
    "every weekend"
  ],
  "timezone": "US/Eastern",
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "groupName": "dagster-plugins",
      "matchPackageNames": [
        "dagster{/,}**"
      ]
    },
    {
      "matchDatasources": ["python"],
      "automerge": false,
      "description": "Python version constraints require manual review due to dbt Mashumaro compatibility with Python 3.14"
    }
  ]
}
