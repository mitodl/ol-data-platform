#vault
GITHUB_TOKEN=

#run dbt with your schema as the target in dagster
DBT_SCHEMA_SUFFIX=
DBT_TRINO_USERNAME=
DBT_TRINO_PASSWORD=

# DuckDB configuration (for local development)
# Set to ~75% of your system's available RAM (e.g., "24GB" for 32GB system, "12GB" for 16GB system)
DBT_DUCKDB_MEMORY_LIMIT=16GB

#interact with S3 buckets
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# video shorts processing
VIDEO_SHORTS_BUCKET=
VIDEO_SHORTS_GOOGLE_SHEETS_ID=
