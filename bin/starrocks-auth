#!/usr/bin/env python3
"""StarRocks authentication helper.

Obtains credentials for StarRocks via one of three flows:
  --mode browser  PKCE authorization-code flow via Keycloak (default)
  --mode ci       Non-interactive client-credentials flow (reads
                  STARROCKS_CLIENT_SECRET)
  --mode vault    Vault dynamic database credentials (native-password service account)

Output modes:
  --output token  Print the raw access token / password
  --output env    Emit shell export statements (eval-able)
  --output exec   Exec a command with credentials in the environment
  --output mysql  Open an interactive mysql session

Tokens from the browser flow are cached in ~/.cache/starrocks-auth/<env>.json
and silently reused until expiry. The refresh token extends the session without
reopening the browser. Use --refresh to force a new browser session.

Use --port-forward to tunnel the StarRocks MySQL port (9030) from the EKS
cluster to localhost via kubectl. Required for local development since the
NLB is internal to the data VPC.

--- dbt workflow (Vault dynamic credentials, recommended for service/automation) ---

  # One-shot: port-forward lives for the duration of the dbt run
  starrocks-auth --env qa --mode vault --port-forward --output exec -- dbt run

  # Two-step: export creds, then run dbt (port-forward must be started separately)
  eval "$(starrocks-auth --env qa --mode vault --port-forward --output env)"
  dbt run --select my_model

  Vault role choices (--vault-role):  readonly | app (default) | admin
  Emits: STARROCKS_USER, STARROCKS_PASSWORD, STARROCKS_HOST

--- Interactive SQL (OIDC, human users) ---

  # MySQL 9.2+ community client — JWT via authentication_openid_connect_client
  starrocks-auth --env qa --port-forward --output mysql

  # Shell session with OIDC token exported (e.g. for DBeaver / DataGrip via JDBC)
  eval "$(starrocks-auth --env qa --port-forward --output env)"
  Emits: STARROCKS_USER, STARROCKS_TOKEN, STARROCKS_HOST

--- CI / non-interactive ---

  export STARROCKS_CLIENT_SECRET=$(
      vault kv get -field=client_secret secret-operations/sso/starrocks
  )
  starrocks-auth --env qa --mode ci --output env

--- Force a fresh browser login ---

  starrocks-auth --env qa --refresh

NOTE on StarRocks auth architecture
-------------------------------------
StarRocks has two disjoint authentication paths:

  1. authentication_jwt (keycloak_jwt Security Integration):
       MySQL wire protocol — client pre-fetches an id_token (PKCE via this
       script), then connects using the authentication_openid_connect_client
       plugin (MySQL 9.2+ only; not available in MariaDB).
       Use: --output mysql with MySQL 9.2+ community client.

  2. authentication_oauth2 (keycloak_oauth2 Security Integration):
       Java JDBC only — the JDBC driver opens a browser for the auth code
       exchange; StarRocks completes the token exchange server-side at
       /api/oauth2. Not usable from the mysql CLI or MariaDB client.
       The StarRocks FE web dashboard (port 8030) is NOT the OAuth2 web UI —
       it uses HTTP Basic Auth exclusively.

  - Native-auth service accounts (dbt, Vault dynamic users): use --mode vault.
    dbt profiles must reference STARROCKS_USER / STARROCKS_PASSWORD env vars,
    not an OIDC token. Arrow Flight SQL also only supports native-password auth.
"""

import argparse
import atexit
import base64
import hashlib
import http.server
import json
import os
import re
import secrets
import shlex
import socket
import subprocess
import sys
import tempfile
import threading
import time
import urllib.error
import urllib.parse
import urllib.request
import webbrowser
from collections.abc import Callable
from pathlib import Path
from typing import Any

import hvac

